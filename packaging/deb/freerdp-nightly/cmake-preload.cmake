if(CMAKE_VERSION GREATER_EQUAL 3.21.0)
  find_package(libcbor 0.10.2 QUIET)
  find_package(libfido2 1.14.0 QUIET)

  if(LIBCBOR_FOUND AND LIBFIDO2_FOUND)
    set(CHANNEL_RDPEWA ON CACHE BOOL "preload")
    set(CHANNEL_RDPEWA_CLIENT ON CACHE BOOL "preload")
  endif()
endif()

find_package(PkgConfig QUIET)
if(PkgConfig_FOUND)
  pkg_check_modules(FREERDP_NIGHTLY_AOM QUIET aom>=2.0)
  pkg_check_modules(FREERDP_NIGHTLY_OPENH264 QUIET openh264)
  pkg_check_modules(FREERDP_NIGHTLY_SOXR QUIET soxr)
  pkg_check_modules(FREERDP_NIGHTLY_YUV QUIET libyuv)
  pkg_check_modules(
    FREERDP_NIGHTLY_GSTREAMER QUIET gstreamer-1.0 gstreamer-base-1.0 gstreamer-video-1.0 gstreamer-app-1.0
  )

  if(FREERDP_NIGHTLY_AOM_FOUND)
    set(WITH_GFX_AV1 ON CACHE BOOL "preload")
  endif()
  if(FREERDP_NIGHTLY_OPENH264_FOUND)
    set(WITH_OPENH264 ON CACHE BOOL "preload")
    set(WITH_OPENH264_LOADING ON CACHE BOOL "preload")
  endif()
  if(FREERDP_NIGHTLY_SOXR_FOUND)
    set(WITH_SOXR ON CACHE BOOL "preload")
  endif()
  if(FREERDP_NIGHTLY_YUV_FOUND)
    set(WITH_YUV ON CACHE BOOL "preload")
  endif()
  if(FREERDP_NIGHTLY_GSTREAMER_FOUND)
    set(WITH_GSTREAMER_1_0 ON CACHE BOOL "preload")
  endif()
endif()

find_path(FREERDP_NIGHTLY_OPENCL_INCLUDE_DIR CL/cl.h)
find_library(FREERDP_NIGHTLY_OPENCL_LIBRARY OpenCL)
if(FREERDP_NIGHTLY_OPENCL_INCLUDE_DIR AND FREERDP_NIGHTLY_OPENCL_LIBRARY)
  set(WITH_OPENCL ON CACHE BOOL "preload")
endif()

find_path(FREERDP_NIGHTLY_GSM_INCLUDE_DIR gsm/gsm.h)
find_library(FREERDP_NIGHTLY_GSM_LIBRARY gsm)
if(FREERDP_NIGHTLY_GSM_INCLUDE_DIR AND FREERDP_NIGHTLY_GSM_LIBRARY)
  set(WITH_GSM ON CACHE BOOL "preload")
endif()

find_path(FREERDP_NIGHTLY_LAME_INCLUDE_DIR lame/lame.h)
find_library(FREERDP_NIGHTLY_LAME_LIBRARY NAMES mp3lame lame)
if(FREERDP_NIGHTLY_LAME_INCLUDE_DIR AND FREERDP_NIGHTLY_LAME_LIBRARY)
  set(WITH_LAME ON CACHE BOOL "preload")
endif()

find_path(FREERDP_NIGHTLY_FAAD2_INCLUDE_DIR faad.h)
find_library(FREERDP_NIGHTLY_FAAD2_LIBRARY faad)
if(FREERDP_NIGHTLY_FAAD2_INCLUDE_DIR AND FREERDP_NIGHTLY_FAAD2_LIBRARY)
  set(WITH_FAAD2 ON CACHE BOOL "preload")
endif()

